{
  "expo": {
    "name": "Machinestreet",
    "jsEngine": "hermes",
    "slug": "frontend",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/AppLogo.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "userInterfaceStyle": "light",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your app needs access to your location to provide better services.",
        "NSLocationAlwaysUsageDescription": "Your app needs access to your location in the background."
      }
    },
    "android": {
      "userInterfaceStyle": "light",
      "package": "com.tamilarasanps.frontend",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "MachineStreet",
      "shortName": "MachineStreet",
      "description": "Connect with verified industrial mechanics across India.",
      "themeColor": "#ffffff",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d2089d71-fd40-4f03-b6ab-bff3a83267b4"
      }
    },
    "owner": "tamildeveloper"
  }
}
